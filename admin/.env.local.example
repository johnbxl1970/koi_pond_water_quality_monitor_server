# Admin app server-side env. Copy to .env.local and fill in.
# Never check .env.local in — it's gitignored.

# Bearer token used to call the NestJS server's /api/admin/* routes.
# Must match ADMIN_API_TOKEN in ../.env (the NestJS server's env file).
KOI_ADMIN_TOKEN=

# Where to reach the NestJS server. Default is local dev.
KOI_SERVER_URL=http://localhost:3000
