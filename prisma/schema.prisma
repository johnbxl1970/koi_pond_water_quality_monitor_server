generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PondRole {
  OWNER
  VIEWER
  TECHNICIAN
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ComparisonOp {
  LT
  LTE
  GT
  GTE
  EQ
  NEQ
}

enum ClaimStatus {
  PENDING
  CONSUMED
  EXPIRED
  REVOKED
}

enum CertStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id                       String          @id @default(cuid())
  email                    String          @unique
  displayName              String?
  passwordHash             String
  createdAt                DateTime        @default(now())
  /// Opt-in flag for contributing anonymized telemetry to the centralized
  /// ML training set. Off by default. See `~/.claude/plans/i-haven-t-decided-yet-witty-piglet.md`.
  dataContributionConsent  Boolean         @default(false)
  pondMembers              PondMember[]
  refreshTokens            RefreshToken[]
  manualReadings           ManualReading[]
}

/// Rotating refresh tokens. The plaintext token is only ever returned to the
/// caller at /auth/login and /auth/refresh; we store its SHA-256 hash so a
/// database leak doesn't hand out live sessions.
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Pond {
  id              String         @id @default(cuid())
  name            String
  volumeM3        Float
  koiCount        Int            @default(0)
  latitude        Float
  longitude       Float
  timezone        String         @default("UTC")
  createdAt       DateTime       @default(now())

  members         PondMember[]
  devices         Device[]
  alertRules      AlertRule[]
  alertEvents     AlertEvent[]
  weatherForecasts WeatherForecast[]
  manualReadings  ManualReading[]
  modelVersions   ModelVersion[]
}

model PondMember {
  id        String   @id @default(cuid())
  pondId    String
  userId    String
  role      PondRole

  pond      Pond     @relation(fields: [pondId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pondId, userId])
}

model Device {
  id          String   @id @default(cuid())
  pondId      String
  hardwareId  String   @unique
  label       String?
  firmwareVer String?
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())

  pond         Pond                @relation(fields: [pondId], references: [id], onDelete: Cascade)
  certificates DeviceCertificate[]
}

/// Pre-registered or freshly-generated claim tied to a specific hardware ID.
/// The plaintext `claimToken` is never stored — only `claimTokenHash`
/// (Argon2id). A claim is consumed exactly once, by the mobile app POSTing
/// `/api/devices/claim` with the plaintext token from the QR.
model DeviceClaim {
  id                  String      @id @default(cuid())
  hardwareId          String      @unique
  claimTokenHash      String
  pubkeyFingerprint   String      // sha256 of the device pubkey, hex
  attestationCertPem  String      @db.Text
  status              ClaimStatus @default(PENDING)
  expiresAt           DateTime
  consumedAt          DateTime?
  consumedByPondId    String?
  createdAt           DateTime    @default(now())
}

/// An issued operational certificate, tracked for revocation + audit.
/// We store only the public cert, never the private key.
model DeviceCertificate {
  id         String     @id @default(cuid())
  deviceId   String
  serial     String     @unique
  certPem    String     @db.Text
  issuedAt   DateTime   @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  status     CertStatus @default(ACTIVE)

  device     Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, status])
}

/// Telemetry is stored in a TimescaleDB hypertable. The migration after
/// `prisma migrate` runs promotes this table to a hypertable and attaches
/// retention + compression policies. Do NOT add a Prisma-managed primary key
/// — Timescale hypertables require the time column in any unique index.
model Telemetry {
  time         DateTime @db.Timestamptz(6)
  deviceId     String
  pondId       String

  phaseSeq     Int      @default(0)
  source       String   @default("device")

  phVal        Float?
  tempC        Float?
  doMgL        Float?
  orpMv        Float?
  tdsPpm       Float?
  turbidityNtu Float?
  nh3TotalPpm  Float?
  nh3FreePpm   Float?
  no2Ppm       Float?
  no3Ppm       Float?
  khDkh        Float?
  ghDgh        Float?

  raw          Json?

  @@id([deviceId, time])
  @@index([pondId, time])
}

/// User-entered water test results (e.g. from API liquid test kits). Persisted
/// as a separate entity so manual data is cleanly separated for analytics, and
/// also fanned into the Telemetry hypertable with `source='manual'` so the
/// existing alerting, recommendation, and SSE paths see them without changes.
/// See ManualReadingsService.create.
model ManualReading {
  id           String   @id @default(cuid())
  pondId       String
  recordedById String
  time         DateTime @default(now())
  notes        String?

  phVal        Float?
  tempC        Float?
  doMgL        Float?
  orpMv        Float?
  tdsPpm       Float?
  turbidityNtu Float?
  nh3TotalPpm  Float?
  nh3FreePpm   Float?
  no2Ppm       Float?
  no3Ppm       Float?
  khDkh        Float?
  ghDgh        Float?

  createdAt    DateTime @default(now())

  pond         Pond     @relation(fields: [pondId], references: [id], onDelete: Cascade)
  recordedBy   User     @relation(fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([pondId, time])
}

model AlertRule {
  id          String        @id @default(cuid())
  pondId      String
  metric      String        // e.g. "phVal", "nh3FreePpm"
  op          ComparisonOp
  threshold   Float
  severity    AlertSeverity @default(WARNING)
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now())

  pond        Pond          @relation(fields: [pondId], references: [id], onDelete: Cascade)
  events      AlertEvent[]
}

model AlertEvent {
  id          String        @id @default(cuid())
  pondId      String
  ruleId      String
  metric      String
  value       Float
  severity    AlertSeverity
  firedAt     DateTime      @default(now())
  resolvedAt  DateTime?

  pond        Pond          @relation(fields: [pondId], references: [id], onDelete: Cascade)
  rule        AlertRule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([pondId, firedAt])
}

model WeatherForecast {
  id              String   @id @default(cuid())
  pondId          String
  fetchedAt       DateTime @default(now())
  forecastForTime DateTime
  tempC           Float?
  precipMm        Float?
  windKph         Float?
  pressureHpa     Float?
  cloudCoverPct   Float?
  raw             Json

  pond            Pond     @relation(fields: [pondId], references: [id], onDelete: Cascade)

  @@index([pondId, forecastForTime])
}

enum PredictionKind {
  DO_FORECAST
  NH3_FORECAST
  ANOMALY_SCORE
}

/// Each row is one prediction emitted by the ML sidecar. The `predicted`
/// JSON holds the model output (forecast trajectory, anomaly score, etc.).
/// `actualForTime` is set later when ground truth is available, enabling
/// back-testing and A/B comparison between model versions. See the ML
/// architecture memo at `~/.claude/plans/i-haven-t-decided-yet-witty-piglet.md`.
model PredictionEvent {
  id             String         @id @default(cuid())
  pondId         String
  kind           PredictionKind
  modelVersionId String
  predictedAt    DateTime       @default(now())
  /// The future timestamp the prediction targets (e.g. predictedAt + 12h).
  /// For ANOMALY_SCORE this is just predictedAt.
  targetTime     DateTime
  predicted      Json
  /// Populated by a back-fill job once telemetry covers `targetTime`.
  actualForTime  DateTime?
  actual         Json?

  modelVersion   ModelVersion   @relation(fields: [modelVersionId], references: [id], onDelete: Restrict)

  @@index([pondId, kind, predictedAt])
  @@index([targetTime, actualForTime])
}

/// Tracks which model produced which predictions. Two flavors:
///
///  * **Global** (`pondId IS NULL`): one model serves all ponds. Promoted
///    from candidate to active only after beating the previous version on
///    held-out data (Phase 1 A/B harness).
///  * **Per-pond** (`pondId IS NOT NULL`): self-supervised on a single pond's
///    history — e.g., the IsolationForest anomaly detector. "Active" is
///    scoped to (kind, pondId), not globally.
///
/// The active-version invariant ("at most one active per kind, per pondId
/// scope") is enforced in code at training time, not via DB constraint —
/// the constraint would break A/B promotions.
model ModelVersion {
  id              String            @id @default(cuid())
  kind            PredictionKind
  /// Null for global models; pond ID for per-pond fine-tuned models.
  pondId          String?
  /// Semver-ish version string (e.g. "do-forecast-v0.3.1" or
  /// "anomaly_iforest-v0-<pondId>-<ts>"). Globally unique.
  version         String            @unique
  /// Pointer to the on-disk artifact (path inside the ml sidecar volume).
  artifactPath    String
  /// Free-form metadata: training data range, hyperparameters, eval metrics.
  metadata        Json
  trainedAt       DateTime          @default(now())
  isActive        Boolean           @default(false)

  pond            Pond?             @relation(fields: [pondId], references: [id], onDelete: Cascade)
  events          PredictionEvent[]

  @@index([kind, isActive])
  @@index([pondId, kind, isActive])
}
