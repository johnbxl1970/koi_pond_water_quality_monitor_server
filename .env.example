NODE_ENV=development
HTTP_PORT=3000

# Bearer token for /api/admin/* endpoints. In prod, rotate and store in a
# secret manager. Empty disables admin routes entirely.
ADMIN_API_TOKEN=dev-admin-token-change-me

DATABASE_URL=postgresql://koi:koi_dev_password@localhost:5432/koi?schema=public

REDIS_URL=redis://localhost:6379

MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TELEMETRY_TOPIC=koi/+/telemetry

OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Provisioning CAs. In dev, generate with: npm run dev:gen-ca
# Production: load from a secret manager / HSM; the attestation root private
# key should live at the factory, not here — this server only needs the
# attestation CA's public cert to verify incoming attestation certificates.

# Operational intermediate CA — signs per-device operational certs. Private
# key is loaded into the server.
CA_OPERATIONAL_CERT_PEM=
CA_OPERATIONAL_KEY_PEM=
CA_OPERATIONAL_CERT_DAYS=365

# Attestation root — verifies that a device's attestation cert chains back to
# a trusted hardware manufacturer. Public cert only; NEVER store the private key.
CA_ATTESTATION_CERT_PEM=

# Ed25519 keypair for signing QR payloads. Mobile apps use the public key
# (served via GET /api/provisioning/qr-signing-pubkey) to verify a scanned QR
# wasn't tampered with.
QR_SIGNING_PRIVATE_KEY_PEM=
QR_SIGNING_PUBLIC_KEY_PEM=

CLAIM_TOKEN_TTL_DAYS=30
PENDING_CSR_TTL_SECONDS=600
